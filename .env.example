# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# TWILIO_ACCOUNT_SID: Optional Twilio account sid for SMS gateway
TWILIO_ACCOUNT_SID=TWILIO_ACCOUNT_SID_PLACEHOLDER

# TWILIO_AUTH_TOKEN: Optional Twilio auth token
TWILIO_AUTH_TOKEN=TWILIO_AUTH_TOKEN_PLACEHOLDER

# TWILIO_FROM_NUMBER: Optional Twilio sending phone number
TWILIO_FROM_NUMBER=TWILIO_FROM_NUMBER_PLACEHOLDER
